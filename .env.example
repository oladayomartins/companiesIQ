# Companies House REST API (free key: https://developer.company-information.service.gov.uk/)
COMPANIES_HOUSE_API_KEY=

# Supabase (https://supabase.com/dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: secret to protect the ingestion + alerts cron endpoints
INGEST_SECRET=

# Optional: enables AI natural-language search parsing on /app/discover
# (Claude Haiku). Without it, NL parsing falls back to the rule-based parser.
ANTHROPIC_API_KEY=

# Optional: sends alert emails via Resend (https://resend.com).
# Without these, the email channel logs intent instead of sending.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alerts@yourdomain.co.uk

# Optional: Google Places API for digital-presence enrichment (GBP, reviews).
# Server-side only — restrict the key to the Places API in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# Optional: Google Analytics 4 measurement ID. A default is baked in; set this
# only to override it. GA tracks production only (never localhost), and only a
# curated set of marketing + app-section pages (no entity-identifier pages).
NEXT_PUBLIC_GA_ID=
