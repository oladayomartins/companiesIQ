# Canonical site origin — used for metadata, canonicals, sitemap and JSON-LD.
# Set to the real production domain (e.g. https://companiesiq.co.uk).
NEXT_PUBLIC_SITE_URL=

# Companies House REST API (free key: https://developer.company-information.service.gov.uk/)
COMPANIES_HOUSE_API_KEY=

# Supabase (https://supabase.com/dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: secret to protect the ingestion + alerts cron endpoints
INGEST_SECRET=

# Optional: enables AI natural-language search parsing on /app/discover
# (Claude Haiku) AND the "Draft with AI" blog generator (/api/blog/generate,
# Claude Opus). Without it, NL parsing falls back to rules and the blog AI
# drafter returns "not configured".
ANTHROPIC_API_KEY=

# Comma-separated allowlist of admin emails. Any signed-in user whose email is
# listed here can access the blog CMS at /app/blog and publish posts.
ADMIN_EMAILS=

# Optional: sends alert emails via Resend (https://resend.com).
# Without these, the email channel logs intent instead of sending.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=alerts@yourdomain.co.uk

# Optional: Google Places API for digital-presence enrichment (GBP, reviews).
# Server-side only — restrict the key to the Places API in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# Optional: Google Analytics 4 measurement ID. A default is baked in; set this
# only to override it. GA tracks production only (never localhost), and only a
# curated set of marketing + app-section pages (no entity-identifier pages).
NEXT_PUBLIC_GA_ID=

# Optional: Stripe secret key (live or test) for the DigitWarehouse package
# checkout (/api/checkout). Without it, package buttons fall back to the booking
# link. Also activate card payments in the Stripe dashboard for live charges.
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (whsec_…) for /api/webhooks/stripe — records the
# purchase + marks the lead on checkout.session.completed, and activates
# CompaniesIQ subscriptions on subscription events.
STRIPE_WEBHOOK_SECRET=

# Recurring price IDs for the CompaniesIQ subscription plans (Analyst / Team),
# created in Stripe (TEST first, then LIVE). The /pricing CTAs resolve these
# server-side via /api/subscribe. Without them, the buttons say subscriptions
# aren't available yet. Create monthly + annual prices per plan.
STRIPE_PRICE_ANALYST_MONTHLY=
STRIPE_PRICE_ANALYST_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
